{
  "expo": {
    "name": "vespaexpert",
    "slug": "vespaexpert",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logonw.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logonw.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logonw.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.vespaexpert"
    },
    "web": {
      "favicon": "./assets/logonw.png",
      "bundler": "metro"
    },
    "plugins": [
      "@react-native-community/datetimepicker"
    ]
  }
}
